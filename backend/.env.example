# Supabase
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_SERVICE_KEY="your-supabase-service-role-key"

# Optional: comma-separated origins allowed to call the API
# Example: "https://your-frontend.vercel.app,https://your-custom-domain.com"
CORS_ORIGIN="http://localhost:5173"

# Optional: required only if you still use Prisma-backed legacy routes
DATABASE_URL="postgresql://user:pass@host:5432/db"

# Optional: Redis cache URL
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="change-me-to-a-random-secret"

# Server
PORT=3000

# Fine calculation
FINE_PER_DAY=5

# Borrow duration (days)
DEFAULT_BORROW_DAYS=14

# Premium domains (comma-separated)
PREMIUM_DOMAINS="iiitk.ac.in"

# OpenAI (for RAG embeddings - optional)
OPENAI_API_KEY=""
